# Override the default UID/GID used inside the opencode container.
# These should match your host user's UID and GID so file permissions
# work correctly on mounted volumes.
#
# Defaults:
#   HOST_UID=502
#   HOST_GID=20
#
# Get your values with:
#   echo $(id -u) $(id -g)
#
# HOST_UID=1000
# HOST_GID=1000
